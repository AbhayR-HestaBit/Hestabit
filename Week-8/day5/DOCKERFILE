FROM python:3.11-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    cmake \
    && rm -rf /var/lib/apt/lists/*

COPY deploy /app/deploy
COPY quantized /app/quantized
COPY README.md /app/README.md

RUN pip install --no-cache-dir --upgrade pip && \
    CMAKE_ARGS="-DGGML_CUDA=OFF" pip install --no-cache-dir fastapi uvicorn pydantic llama-cpp-python

ENV MODEL_PATH=/app/quantized/model.gguf
ENV HOST=0.0.0.0
ENV PORT=8000

EXPOSE 8000

CMD ["uvicorn", "deploy.app:app", "--host", "0.0.0.0", "--port", "8000"]
